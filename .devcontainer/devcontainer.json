{
    "name": "ML Network Traffic Forecasting",
    "image": "mcr.microsoft.com/devcontainers/python:3.11",
    "hostRequirements": {
        "cpus": 4,
        "memory": "16gb"
    },
    "postCreateCommand": "pip install --upgrade pip && pip install -r requirements-cloud.txt",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python"
            }
        }
    },
    "forwardPorts": [],
    "remoteUser": "vscode"
}
